{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://sistema-funkos.test/api"
      }
    },
    "local": {
      "channel": "local",
      "env": {
        "API_URL": "http://sistema-funkos.test/api"
      }
    },
    "staging": {
      "channel": "staging",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://el-jardin-de-la-macetas-app-8rssws-51e10e-187-77-212-199.sslip.io/api"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://eljardindelasmacetas.com/api"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./path-to-service-account.json",
        "track": "production"
      }
    }
  }
}
