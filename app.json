{
  "expo": {
    "name": "Funkomacetas",
    "slug": "app-funkos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.funkomacetas.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Funkomacetas necesita acceso a la camara para tomar fotos de productos",
        "NSPhotoLibraryUsageDescription": "Funkomacetas necesita acceso a la biblioteca de fotos para seleccionar imagenes"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C5CE7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.funkomacetas.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Funkomacetas necesita acceso a la biblioteca de fotos",
          "cameraPermission": "Funkomacetas necesita acceso a la camara para tomar fotos"
        }
      ]
    ],
    "extra": {
      "apiUrlStaging": "https://eljardindelasmacetas.com/api",
      "apiUrlProduction": "http://sistema-funkos.test/api",
      "eas": {
        "projectId": "1e0910ac-a54c-4f41-9762-763ce701cfa9"
      }
    },
    "owner": "alainlemus",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1e0910ac-a54c-4f41-9762-763ce701cfa9"
    }
  }
}
