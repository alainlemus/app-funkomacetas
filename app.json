{
  "expo": {
    "name": "El Jardín de las Macetas",
    "slug": "app-funkos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.funkomacetas.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Funkomacetas necesita acceso a la camara para tomar fotos de productos",
        "NSPhotoLibraryUsageDescription": "Funkomacetas necesita acceso a la biblioteca de fotos para seleccionar imagenes",
        "NSPhotoLibraryAddUsageDescription": "Funkomacetas necesita acceso para guardar fotos",
        "NSFaceIDUsageDescription": "Funkomacetas usa Face ID para iniciar sesion rapidamente",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "sslip.io": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionRequiresForwardSecrecy": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.0"
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C5CE7",
        "foregroundImage": "./assets/logo.png"
      },
      "package": "com.funkomacetas.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Funkomacetas necesita acceso a la biblioteca de fotos",
          "cameraPermission": "Funkomacetas necesita acceso a la camara para tomar fotos"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1e0910ac-a54c-4f41-9762-763ce701cfa9"
      }
    },
    "owner": "alainlemus",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1e0910ac-a54c-4f41-9762-763ce701cfa9"
    }
  }
}
